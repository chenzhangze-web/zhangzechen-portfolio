const sizeMap = {
  sm: { icon: 'w-4 h-4', container: 'w-8 h-8' },
  md: { icon: 'w-5 h-5', container: 'w-10 h-10' },
  lg: { icon: 'w-6 h-6', container: 'w-12 h-12' },
