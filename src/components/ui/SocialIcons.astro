---

<div class="flex items-center gap-3">
  {links.map((link) => {
    const d = iconPaths[link.icon] ?? null;
    const isAnchor = link.url.startsWith('#');
    return (
      <a
        href={link.url}
        target={isAnchor ? undefined : '_blank'}
        rel={isAnchor ? undefined : 'noopener noreferrer'}
        aria-label={link.platform}
        class="w-10 h-10 flex items-center justify-center rounded-lg border-2 border-heading text-heading hover:bg-accent hover:border-accent hover:text-white transition-all"
      >
        {d ? (
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d={d} />
          </svg>
        ) : (
          <span class="text-xs font-semibold">{link.icon.toUpperCase()}</span>
        )}
      </a>
    );
  })}
</div>
