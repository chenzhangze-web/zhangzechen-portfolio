---
import type { PublicationEntry } from '@/types';

interface Props {
  entry: PublicationEntry;
}

const { entry } = Astro.props;
const authorPositionLabel = {
  zh: entry.authorPosition === 'first' ? '第一作者' : entry.authorPosition === 'second' ? '第二作者' : '合作者',
  en: entry.authorPosition === 'first' ? 'First Author' : entry.authorPosition === 'second' ? 'Second Author' : 'Co-Author',
};
const authorPosSuffix = entry.totalAuthors > 0 ? ` (${entry.authorPosition === 'first' ? '1' : entry.authorPosition === 'second' ? '2' : 'co'}/${entry.totalAuthors})` : '';
const isProfileAuthor = (author: string) => author === 'Zhangze Chen' || author === 'Z. Chen';
const authorBadgeClass = entry.authorPosition === 'first'
  ? 'bg-[#1a237e]/10 text-heading border-[#1a237e]/15'
  : 'bg-[#7a6a55]/10 text-[#6f6254] border-[#7a6a55]/15';
---

<div
  class="publication-card reveal group relative overflow-hidden rounded-[6px] border border-white/70 bg-white/78 p-5 shadow-[0_14px_38px_rgba(82,70,52,.10)] backdrop-blur-sm transition-all duration-300 hover:-translate-y-1.5 hover:border-accent/35 hover:bg-white/90 hover:shadow-[0_22px_55px_rgba(66,107,194,.18)] cursor-pointer"
  data-category={entry.category}
  data-lightbox-slug={entry.slug}
>
  <div class="absolute inset-x-0 top-0 h-1 bg-gradient-to-r from-[#1a237e] via-[#426bc2] to-[#9b7b50] opacity-70 transition-opacity duration-300 group-hover:opacity-100"></div>

  <!-- Author position badge -->
  <div class="flex items-center justify-between mb-2">
    <span class={`text-[10px] font-semibold px-2.5 py-1 rounded-full border ${authorBadgeClass}`}>
      <span class="lang-zh">{authorPositionLabel.zh}{authorPosSuffix}</span>
      <span class="lang-en">{authorPositionLabel.en}{authorPosSuffix}</span>
    </span>
    <span class="text-[10px] font-semibold text-muted/70">{entry.year}</span>
  </div>

  <!-- Title -->
  <h3 class="text-[15px] font-display font-[800] text-heading leading-snug mb-3 transition-colors group-hover:text-accent">
    <span class="lang-zh">{entry.titleZh}</span>
    <span class="lang-en">{entry.titleEn}</span>
  </h3>

  <!-- Authors -->
  <p class="text-xs text-muted mb-3 leading-relaxed">
    {entry.authors.map((author) => (
      isProfileAuthor(author)
        ? <span class="font-[700] text-black">{author}</span>
        : author
    )).reduce((prev: any, curr: any) => [prev, ', ', curr] as any)}
  </p>

  <!-- Journal -->
  <p class="text-[10px] text-muted/70 italic mb-4">
    <span class="lang-zh">{entry.journalZh}</span>
    <span class="lang-en">{entry.journalEn}</span>
  </p>

  <!-- Links -->
  {entry.links.length > 0 && (
    <div class="flex items-center justify-between gap-3 pt-3 border-t border-border/50">
      <span class="text-[10px] text-muted/45">
        <span class="lang-zh">点击查看详情</span>
        <span class="lang-en">Open details</span>
      </span>
      {entry.links.map((link) => (
        <a
          href={link.url}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center rounded-full bg-accent/8 px-2.5 py-1 text-[10px] font-semibold text-accent transition-all hover:bg-accent hover:text-white"
          onclick="event.stopPropagation()"
        >
          {link.label} <span class="ml-1 transition-transform group-hover:translate-x-0.5">→</span>
        </a>
      ))}
    </div>
  )}
</div>

<script>
  // Dispatch open-lightbox event on click
  document.querySelectorAll('[data-lightbox-slug]').forEach((card) => {
    card.addEventListener('click', () => {
      const slug = (card as HTMLElement).dataset.lightboxSlug;
      if (slug) {
        window.dispatchEvent(new CustomEvent('open-lightbox', { detail: { slug } }));
      }
    });
  });
</script>
