---
interface Props {
  title: string;
  issuer: string;
  issueDate: string;
  expiryDate: string | null;
  badgeUrl: string | null;
  verifyUrl: string | null;
}

const { title, issuer, issueDate, expiryDate, badgeUrl, verifyUrl } = Astro.props;

function formatDate(d: string): string {
  const [y, m] = d.split('-');
  const months = [
    'Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun',
    'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec',
  ];
  return `${months[parseInt(m ?? '1') - 1]} ${y}`;
}
---

<div class="reveal flex items-start gap-4 p-5 bg-white/60 backdrop-blur-sm rounded-card border border-border hover:border-accent/20 hover:shadow-md transition-all duration-300">
  <!-- Badge / icon column -->
  <div class="shrink-0">
    {badgeUrl ? (
      <img src={badgeUrl} alt={title} class="w-14 h-14 rounded-lg object-contain bg-surface" />
    ) : (
      <div class="w-14 h-14 rounded-lg bg-accent/10 flex items-center justify-center">
        <svg class="w-6 h-6 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z" />
        </svg>
      </div>
    )}
  </div>
  <!-- Details -->
  <div class="flex-1 min-w-0">
    <h3 class="font-semibold text-heading text-sm leading-tight">{title}</h3>
    <p class="text-muted text-xs mt-1">{issuer}</p>
    <p class="text-muted/70 text-[11px] mt-0.5">
      Issued {formatDate(issueDate)}{expiryDate ? ` · Expires ${formatDate(expiryDate)}` : ' · No expiration'}
    </p>
  </div>
  <!-- Verify -->
  {verifyUrl && (
    <a
      href={verifyUrl}
      class="shrink-0 text-xs font-medium text-accent hover:text-accent-hover transition-colors mt-1"
    >
      Verify →
    </a>
  )}
</div>
