---
interface Props {
  name: string;
  nameEn: string;
  roleZh: string;
  roleEn: string;
  institutionZh: string;
  institutionEn: string;
  avatarSrc: string;
  avatarAlt?: string;
}

const { name, nameEn, roleZh, roleEn, institutionZh, institutionEn, avatarSrc, avatarAlt = `${nameEn}'s photo` } =
  Astro.props;
---

<div class="group w-[200px] shrink-0">
  <!-- Black lanyard cord with slow swing on group hover -->
  <div class="flex justify-center">
    <div class="w-1.5 h-20 bg-black/80 rounded-t-full origin-top transition-transform duration-[2500ms] ease-in-out group-hover:animate-[cord-swing_2.5s_ease-in-out_infinite]" style="will-change: transform;"></div>
  </div>
  <div class="flex justify-center -mt-1 mb-0.5">
    <svg width="40" height="14" viewBox="0 0 40 14" class="text-gray-400">
      <rect x="0" y="0" width="40" height="14" rx="7" fill="currentColor" />
      <rect x="16" y="66" width="8" height="8" rx="4" fill="currentColor" />
    </svg>
  </div>

  <!-- Postcard card -->
  <div class="bg-white rounded-[4px] overflow-hidden shadow-[0_10px_30px_rgba(0,0,0,.1)] transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_15px_40px_rgba(0,0,0,.15)] hover:rotate-[0.5deg]"
    style="padding: 15px 15px 40px;">
    <!-- Photo -->
    <div class="w-full aspect-[3/4] bg-gray-100 rounded-[2px] overflow-hidden mb-4">
      <img
        src={avatarSrc}
        alt={avatarAlt}
        class="w-full h-full object-cover"
      />
    </div>
    <!-- Name -->
    <p class="font-display font-[700] text-heading text-center text-base leading-tight">
      <span class="lang-zh">{name}</span>
      <span class="lang-en">{nameEn}</span>
    </p>
    <!-- Role -->
    <p class="text-accent text-xs text-center mt-1 font-medium">
      <span class="lang-zh">{roleZh}</span>
      <span class="lang-en">{roleEn}</span>
    </p>
    <!-- Institution -->
    <p class="text-muted text-[10px] text-center mt-2 uppercase tracking-wider">
      <span class="lang-zh">{institutionZh}</span>
      <span class="lang-en">{institutionEn}</span>
    </p>
  </div>
</div>

<style>
  @keyframes cord-swing {
    0%, 100% { transform: rotate(0deg); }
    25% { transform: rotate(1.5deg); }
    75% { transform: rotate(-1.5deg); }
  }
  @media (prefers-reduced-motion: reduce) {
    .group-hover\:animate-\[cord-swing_2\.5s_ease-in-out_infinite\] {
      animation: none !important;
    }
  }
</style>
