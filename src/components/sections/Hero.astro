---
interface Props {
  name: string;
  title: string;
  institution: string;
  institutionZh: string;
  avatarSrc: string;
  avatarAlt: string;
}

const { name, institution, institutionZh, avatarSrc, avatarAlt } = Astro.props;

// Hero letter layout adapted from temp.html. Tweak left/top/fontSize here for quick visual tuning.
// Keep z-index positive here: negative layers can disappear behind section backgrounds.
const letters = [
  { char: 'P', left: '8%',  top: '15%',  fontSize: 'clamp(118px,19vw,270px)', zIndex: 4, rotate: '15deg', delay: '0.0s',  dur: '4.2s', y: '-8px' },
  { char: 'o', left: '22%', top: '30%',  fontSize: 'clamp(90px,15vw,210px)',  zIndex: 3, rotate: '-9deg', delay: '0.15s', dur: '3.6s', y: '7px' },
  { char: 'R', left: '30%', top: '0%',   fontSize: 'clamp(108px,17vw,240px)', zIndex: 5, rotate: '-5deg', delay: '0.3s',  dur: '4.8s', y: '-7px' },
  { char: 'T', left: '43%', top: '-14%', fontSize: 'clamp(118px,19vw,270px)', zIndex: 2, rotate: '1deg',  delay: '0.45s', dur: '3.4s', y: '-6px' },
  { char: 'f', left: '55%', top: '5%',   fontSize: 'clamp(92px,15vw,210px)',  zIndex: 5, rotate: '12deg', delay: '0.6s',  dur: '4.0s', y: '-7px' },
  { char: 'O', left: '60%', top: '22%',  fontSize: 'clamp(86px,14vw,196px)',  zIndex: 4, rotate: '1deg',  delay: '0.75s', dur: '3.8s', y: '7px' },
  { char: 'L', left: '72%', top: '12%',  fontSize: 'clamp(102px,16vw,225px)', zIndex: 5, rotate: '-3deg', delay: '0.9s',  dur: '4.4s', y: '-8px' },
  { char: 'i', left: '82%', top: '35%',  fontSize: 'clamp(78px,13vw,175px)',  zIndex: 3, rotate: '16deg', delay: '1.05s', dur: '3.2s', y: '7px' },
  { char: 'o', left: '88%', top: '45%',  fontSize: 'clamp(56px,9vw,124px)',   zIndex: 4, rotate: '1deg',  delay: '1.2s',  dur: '4.6s', y: '-6px' },
];
---

<section class="hero-section relative min-h-[88vh] flex flex-col items-center justify-center overflow-hidden px-6 py-12">

  <!-- Institution tag (top-right, gray plain text) -->
  <div class="institution-tag absolute z-10 text-right">
    <p class="text-xs text-muted/70 font-medium tracking-wide">
      <span class="lang-zh">{institutionZh}</span>
      <span class="lang-en">{institution}</span>
    </p>
    <p class="text-[10px] text-muted/50 tracking-wider">
      <span class="lang-zh">教育技术学</span>
      <span class="lang-en">Educational Technology</span>
    </p>
  </div>

  <!-- Hero cluster: all letters + avatar in one relative container -->
  <div class="portfolio-text-bg hero-cluster relative mx-auto select-none">
    {letters.map(({ char, left, top, fontSize, zIndex, rotate, delay, dur, y }) => (
      <span
        class="floating-letter absolute font-display font-[900] leading-none"
        style={{
          left,
          top,
          fontSize,
          zIndex: String(zIndex),
          color: '#0a0a0a',
          '--r': rotate,
          '--float-y': y,
          '--enter-delay': delay,
          '--dur': dur,
          '--float-delay': `calc(${delay} + 0.7s)`,
        }}
      >
        {char}
      </span>
    ))}

    <!-- '26 badge (upper-right) -->
    <span
      class="floating-letter badge-26 absolute font-display font-[800] leading-none"
      style={{
          left: '62%',
          top: '12%',
          fontSize: 'clamp(38px,5.8vw,76px)',
          zIndex: '8',
          color: '#426bc2',
          '--r': '-5deg',
          '--float-y': '-5px',
          '--enter-delay': '1.1s',
          '--dur': '4.0s',
          '--float-delay': 'calc(1.1s + 0.7s)',
        }}
    >
      '26
    </span>

    <!-- Avatar sits on the top visual layer. -->
    <img
      src={avatarSrc}
      alt={avatarAlt}
      class="hero-avatar absolute pointer-events-none"
      style="left: 50%; top: var(--avatar-top, 46%); transform: translate(-50%, -50%); z-index: 30;"
    />

    <!-- Name inside cluster, lower-left -->
    <div
      class="hero-name absolute font-display font-[800] leading-tight"
      style="left: 6%; top: 67%; z-index: 8; color: #426bc2; font-size: clamp(32px,4vw,54px);"
    >
      <span>{name}</span>
    </div>
  </div>

  <!-- Scroll hint -->
  <div class="absolute bottom-8 flex flex-col items-center gap-2 text-muted/50 reveal" style="transition-delay: 600ms">
    <span class="text-[10px] uppercase tracking-widest"><span class="lang-zh">向下滚动</span><span class="lang-en">Scroll</span></span>
    <svg class="w-5 h-5 animate-bounce" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
    </svg>
  </div>
</section>

<style>
  .hero-cluster {
    width: min(84vw, 1080px);
    height: clamp(470px, 66vh, 640px);
    --avatar-top: 46%;
  }

  .institution-tag {
    top: 2.35rem;
    right: clamp(5.25rem, 12vw, 15rem);
  }

  .hero-avatar {
    width: clamp(200px, 20vw, 260px);
    max-width: 58%;
    height: auto;
    object-fit: contain;
    display: block;
  }

  .floating-letter {
    opacity: 0;
    pointer-events: auto;
    transition: color 0.25s ease;
    animation-name: letter-enter, letter-breathe;
    animation-duration: 0.7s, var(--dur, 4s);
    animation-timing-function: ease-out, ease-in-out;
    animation-fill-mode: forwards, none;
    animation-iteration-count: 1, infinite;
    animation-delay: var(--enter-delay, 0s), var(--float-delay, 0.7s);
  }

  .floating-letter:hover { color: #426bc2 !important; }
  .badge-26 { transition: color 0.25s ease; }
  .badge-26:hover { color: #1a237e !important; }

  @keyframes letter-enter {
    0%   { opacity: 0; transform: rotate(var(--r, 0deg)) scale(0.85); }
    100% { opacity: 1; transform: rotate(var(--r, 0deg)) scale(1); }
  }

  @keyframes letter-breathe {
    0%, 100% { transform: rotate(var(--r, 0deg)) translateY(0) scale(1); }
    50%       { transform: rotate(var(--r, 0deg)) translateY(var(--float-y, -6px)) scale(1.03); }
  }

  @media (prefers-reduced-motion: reduce) {
    .floating-letter {
      animation: none;
      opacity: 1;
      transition: none;
    }
  }

  @media (max-width: 720px) {
    .hero-cluster {
      width: min(94vw, 520px);
      height: clamp(430px, 62vh, 560px);
      --avatar-top: 47%;
    }

    .institution-tag {
      top: 2rem;
      right: 4.5rem;
    }

    .hero-avatar {
      width: clamp(150px, 38vw, 200px);
      max-width: 56%;
    }

    .hero-name {
      left: 2% !important;
      top: 83% !important;
      font-size: clamp(22px, 7.2vw, 30px) !important;
      line-height: 1.05 !important;
      white-space: nowrap !important;
    }
  }
</style>
