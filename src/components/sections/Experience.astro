---
import type { ExperienceEntry } from '@/types';
import TimelineItem from '../ui/TimelineItem.astro';

interface Props {
  entries: ExperienceEntry[];
}

const { entries } = Astro.props;
---

<section class="py-24 md:py-32 px-6">
  <div class="max-w-4xl mx-auto">
    <!-- Section heading -->
    <div class="reveal text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-extrabold text-heading tracking-tight">
        <span class="lang-zh">科研经历</span>
        <span class="lang-en">Experience</span>
      </h2>
      <div class="w-16 h-1 bg-accent/40 rounded-full mt-4 mx-auto"></div>
    </div>

    <!-- Timeline -->
    <div>
      {entries.map((entry, i) => (
        <TimelineItem
          titleZh={entry.titleZh}
          titleEn={entry.titleEn}
          organizationZh={entry.organizationZh}
          organizationEn={entry.organizationEn}
          startDate={entry.startDate}
          endDate={entry.endDate}
          descriptionZh={entry.descriptionZh}
          descriptionEn={entry.descriptionEn}
          tagsZh={entry.tagsZh}
          tagsEn={entry.tagsEn}
          isLast={i === entries.length - 1}
        />
      ))}
    </div>

    <!-- Empty state -->
    {entries.length === 0 && (
      <p class="reveal text-muted text-center text-sm">
        <span class="lang-zh">暂无科研经历。</span>
        <span class="lang-en">No experience entries yet.</span>
      </p>
    )}
  </div>
</section>
