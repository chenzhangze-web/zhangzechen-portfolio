---
import type { CertEntry } from '@/types';
import CertCard from '../ui/CertCard.astro';

interface Props {
  certs: CertEntry[];
}

const { certs } = Astro.props;
---

<section class="py-24 md:py-32 px-6">
  <div class="max-w-4xl mx-auto">
    <!-- Section heading -->
    <div class="reveal text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-extrabold text-heading tracking-tight font-display">
        <span class="lang-zh">教育背景与证书</span>
        <span class="lang-en">Education &amp; Certifications</span>
      </h2>
    </div>

    <!-- Education cards -->
    <div class="space-y-6 mb-16">
      <!-- Ph.D. -->
      <div class="reveal bg-white rounded-[4px] shadow-[0_10px_30px_rgba(0,0,0,.1)] p-6 flex gap-4 items-start" style="transition-delay: 100ms">
        <div class="w-12 h-12 rounded-full bg-accent/10 flex items-center justify-center shrink-0">
          <span class="text-accent font-display font-[800] text-lg">PhD</span>
        </div>
        <div>
          <h3 class="font-display font-[700] text-heading text-lg">
            <span class="lang-zh">教育技术学直博研究生</span>
            <span class="lang-en">Ph.D. (Direct-Entry), Educational Technology</span>
          </h3>
          <p class="text-muted text-sm mt-0.5">
            <span class="lang-zh">浙江师范大学</span>
            <span class="lang-en">Zhejiang Normal University</span>
          </p>
          <p class="text-muted text-xs mt-1">
            <span class="lang-zh">2023 — 至今</span>
            <span class="lang-en">2023 — Present</span>
          </p>
        </div>
      </div>

      <!-- B.S. -->
      <div class="reveal bg-white rounded-[4px] shadow-[0_10px_30px_rgba(0,0,0,.1)] p-6 flex gap-4 items-start" style="transition-delay: 200ms">
        <div class="w-12 h-12 rounded-full bg-heading/10 flex items-center justify-center shrink-0">
          <span class="text-heading font-display font-[800] text-lg">BS</span>
        </div>
        <div>
          <h3 class="font-display font-[700] text-heading text-lg">
            <span class="lang-zh">教育技术学本科</span>
            <span class="lang-en">B.S. / B.Ed., Educational Technology</span>
          </h3>
          <p class="text-muted text-sm mt-0.5">
            <span class="lang-zh">浙江师范大学</span>
            <span class="lang-en">Zhejiang Normal University</span>
          </p>
          <p class="text-muted text-xs mt-1">2019 — 2023</p>
        </div>
      </div>
    </div>

    <!-- Certifications sub-heading -->
    <div class="reveal text-center mb-8">
      <h3 class="text-2xl font-display font-[700] text-heading">
        <span class="lang-zh">证书与服务</span>
        <span class="lang-en">Certifications &amp; Service</span>
      </h3>
    </div>

    <div class="space-y-4">
      {certs.map((entry) => (
        <CertCard
          title={entry.title}
          issuer={entry.issuer}
          issueDate={entry.issueDate}
          expiryDate={entry.expiryDate}
          badgeUrl={entry.badgeUrl}
          verifyUrl={entry.verifyUrl}
        />
      ))}

      <!-- CAE Reviewer -->
      <div class="reveal bg-white rounded-[4px] shadow-[0_10px_30px_rgba(0,0,0,.1)] p-5 flex gap-4 items-start" style="transition-delay: 300ms">
        <div class="w-10 h-10 rounded-full bg-accent/10 flex items-center justify-center shrink-0">
          <svg class="w-5 h-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
          </svg>
        </div>
        <div>
          <h3 class="font-display font-[700] text-heading">
            <span class="lang-zh">审稿人</span>
            <span class="lang-en">Reviewer</span>
          </h3>
          <p class="text-muted text-sm">Computers &amp; Education (CAE), Elsevier</p>
          <p class="text-muted text-xs mt-0.5">
            <span class="lang-zh">SSCI 顶级期刊</span>
            <span class="lang-en">SSCI Top-Tier Journal</span>
          </p>
        </div>
      </div>
    </div>

    {certs.length === 0 && (
      <p class="reveal text-muted text-center text-sm">
        <span class="lang-zh">暂无证书记录。</span>
        <span class="lang-en">No certifications listed yet.</span>
      </p>
    )}
  </div>
</section>
